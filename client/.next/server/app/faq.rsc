1a:Tcac,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What does Spark Innovations sell?","acceptedAnswer":{"@type":"Answer","text":"Spark Innovations is an authorized distributor of Kutchina kitchen appliances including chimneys, hobs, cooktops, and water purifiers. We offer authentic products with full warranty support."}},{"@type":"Question","name":"Where are you located?","acceptedAnswer":{"@type":"Answer","text":"We are based in Kolkata and serve customers across India with fast and reliable delivery."}},{"@type":"Question","name":"Do you ship across India?","acceptedAnswer":{"@type":"Answer","text":"Yes, we offer nationwide shipping. Delivery times vary based on location but are typically 3-7 business days."}},{"@type":"Question","name":"What are the shipping charges?","acceptedAnswer":{"@type":"Answer","text":"Free shipping is available on orders above ₹5000. For orders below that, shipping charges are calculated based on your location."}},{"@type":"Question","name":"How do I track my order?","acceptedAnswer":{"@type":"Answer","text":"Once your order ships, you'll receive a tracking number via email. You can use this to track your package in real-time."}},{"@type":"Question","name":"What if my package is damaged?","acceptedAnswer":{"@type":"Answer","text":"We pack all items carefully with insurance. If your product arrives damaged, please contact us immediately with photos and we'll arrange a replacement."}},{"@type":"Question","name":"What is your return policy?","acceptedAnswer":{"@type":"Answer","text":"We offer a 30-day return policy on unused products in original packaging. Please contact our support team to initiate the return process."}},{"@type":"Question","name":"How long does a refund take?","acceptedAnswer":{"@type":"Answer","text":"Refunds are processed within 7-10 business days after we receive and inspect the returned item."}},{"@type":"Question","name":"Are all products authentic?","acceptedAnswer":{"@type":"Answer","text":"Yes, 100% authentic. We are an authorized distributor of Kutchina. All products come with manufacturer warranty."}},{"@type":"Question","name":"What warranty is provided?","acceptedAnswer":{"@type":"Answer","text":"Products come with Kutchina manufacturer warranty. Typically 1-3 years depending on product. Warranty card will be provided with your order."}},{"@type":"Question","name":"Do you provide installation service?","acceptedAnswer":{"@type":"Answer","text":"We offer installation guidance and can recommend certified technicians in your area. Please contact us for details."}},{"@type":"Question","name":"How do I create an account?","acceptedAnswer":{"@type":"Answer","text":"Click on Sign Up on the top right of the website. Fill in your details and verify your email to get started."}},{"@type":"Question","name":"Can I modify my order?","acceptedAnswer":{"@type":"Answer","text":"Orders can only be modified within 2 hours of placement. Please contact support immediately if you need changes."}},{"@type":"Question","name":"How do I contact customer support?","acceptedAnswer":{"@type":"Answer","text":"You can reach us via email, phone, or WhatsApp. Check the Contact page for all communication channels."}}]}13:["$","$1","c",{"children":[null,[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1a"}}],"$L1b"]]}]
