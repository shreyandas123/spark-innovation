# URL of your deployed backend (server) — no trailing slash
# Local dev: http://localhost:4000
# Production: https://your-server.vercel.app
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# Google OAuth client ID (same value as server GOOGLE_CLIENT_ID)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# Public URL of this Next.js app (used for Open Graph metadata)
NEXT_PUBLIC_SITE_URL=https://your-client.vercel.app
